<Window x:Class="SatelliteTracker.ChangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SatelliteTracker"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        WindowStyle="None"
        Title="ChangeDialog" Height="300" Width="500" WindowStartupLocation="CenterOwner" Background="#FF1E1E1E" ResizeMode="NoResize">
    <Grid ScrollViewer.VerticalScrollBarVisibility="Auto">

        <Grid Grid.Row="0"
          Background="#FF1E1E1E"
          MouseLeftButtonDown="TitleBar_MouseDown" Margin="0,0,0,282">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
        </Grid>

        <Rectangle Fill="#FF2A2A2A" RadiusX="30" RadiusY="30" Margin="10,0,0,0" Height="264" VerticalAlignment="Center" HorizontalAlignment="Left" Width="480" />

        <TextBlock Text="Название:" Margin="23,0,0,247" Foreground="White" FontFamily="Impact" FontSize="18" Height="19" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="82"/>

        <Border CornerRadius="10"
        BorderBrush="Gray"
        BorderThickness="1"
        Background="White"
        Padding="5" Margin="109,0,0,242" Height="29" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="349">

            <TextBox x:Name="TLEnameTB" BorderThickness="0"
             Background="Transparent"
             FontSize="14" Height="28" VerticalAlignment="Center"/>
        </Border>
        <Border CornerRadius="10"
            BorderBrush="Gray"
            BorderThickness="1"
            Background="White"
            Padding="5" Margin="74,0,0,205" Height="22" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="100">

            <xctk:ColorPicker x:Name="ColorPicker" BorderThickness="0"
                Background="Transparent"
                FontSize="14" Margin="0,-6,0,-6" HorizontalAlignment="Center" Width="80"/>
        </Border>
        <Border CornerRadius="10"
            BorderBrush="Gray"
            BorderThickness="1"
            Background="White"
            Padding="5" Margin="64,107,0,0" Height="53" VerticalAlignment="Top" HorizontalAlignment="Left" Width="394">

            <TextBox x:Name="Tle1TB" BorderThickness="0"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Background="Transparent"
                FontSize="14" Height="45" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="TLE1:" Margin="23,0,0,171" Foreground="White" FontFamily="Impact" FontSize="18" Height="22" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="35"/>
        <TextBlock Text="TLE2:" Margin="23,0,0,108" Foreground="White" FontFamily="Impact" FontSize="18" Height="22" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="35"/>
        <Border CornerRadius="10"
            BorderBrush="Gray"
            BorderThickness="1"
            Background="White"
            Padding="5" Margin="64,170,0,0" Height="53" VerticalAlignment="Top" HorizontalAlignment="Left" Width="394">

            <TextBox x:Name="Tle2TB" BorderThickness="0"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Background="Transparent"
                FontSize="14" Height="46" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="Цвет:" Margin="23,0,0,208" Foreground="White" FontFamily="Impact" FontSize="18" Height="19" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="46"/>
        <Border CornerRadius="10"
            BorderBrush="Gray"
            BorderThickness="1"
            Background="#FFF73232"
            Padding="5" Margin="376,243,0,0" Height="28" VerticalAlignment="Top" HorizontalAlignment="Left" Width="100">
            <Button x:Name="CancelButton" Margin="-6,-6,-6,-6" Background="#00DDDDDD" Content="ОТМЕНА" FontFamily="Impact" FontSize="18" Foreground="White" Click="CancelButton_Click"/>
        </Border>
        <Border CornerRadius="10"
            BorderBrush="Gray"
            BorderThickness="1"
            Background="#FF7DFF62"
            Padding="5" Margin="271,243,0,0" Height="28" VerticalAlignment="Top" HorizontalAlignment="Left" Width="100">

            <Button x:Name="OKbutton" Margin="-6,-6,-6,0" Background="#00DDDDDD" Content="ОК" FontFamily="Impact" FontSize="18" Foreground="White" Height="28" VerticalAlignment="Top" Click="OKbutton_Click"/>
        </Border>
    </Grid>
</Window>
